# Replace {$SITE_ADDRESS} with your domain or :80 for IP-only HTTP.
# Set the env var before starting Caddy (the deploy script does this).
{$SITE_ADDRESS} {
	# Static frontend build
	root * /opt/creative-gen/frontend/dist
	encode zstd gzip

	# API + backend-served paths → uvicorn on 127.0.0.1:8000
	@backend path /auth* /shopify* /upload* /generate* /history* /download* /files* /spaces* /video* /tools* /voice* /adgenius* /chat* /image-edit* /avatar* /translate* /profile*
	reverse_proxy @backend 127.0.0.1:8000

	# /welcome/ serves the static landing directly (Caddy handles it via file_server below)
	# SPA fallback: anything that isn't a real file goes to index.html so React Router works.
	try_files {path} /index.html
	file_server
}
