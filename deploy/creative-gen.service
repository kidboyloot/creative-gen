[Unit]
Description=Creative Gen FastAPI backend
After=network.target

[Service]
Type=simple
User=creativegen
WorkingDirectory=/opt/creative-gen/backend
EnvironmentFile=/opt/creative-gen/backend/.env
ExecStart=/opt/creative-gen/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=on-failure
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
