{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/((?!auth|shopify|upload|generate|history|download|files|spaces|video|tools|voice|adgenius|chat|image-edit|avatar|translate|profile|teams|welcome).*)", "destination": "/index.html" }
  ]
}
